# Frontend env — copy to .env.local and fill in to enable the real API path.
# Without these, the app keeps running against lib/mock-data.ts (Phase 1–2 demo).

# Clerk — get these from your Clerk dashboard (API Keys page)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional Clerk redirects
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000
