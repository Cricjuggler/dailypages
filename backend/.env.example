# Postgres — Neon recommended; local docker-compose sets this automatically
DATABASE_URL=postgresql+asyncpg://dailypages:dailypages@localhost:5432/dailypages

# Clerk — get these from your Clerk dashboard (Backend API)
CLERK_ISSUER=https://YOUR-INSTANCE.clerk.accounts.dev
CLERK_JWKS_URL=https://YOUR-INSTANCE.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=

# Cloudflare R2 — S3-compatible
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dailypages-uploads
R2_PUBLIC_BASE=

# Async jobs (Celery + Redis)
# Local: redis://localhost:6379/0 — Production: use Upstash's TLS Redis URL (rediss://...)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3037

# AI providers (Phase 5)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-large
VOYAGE_EMBED_DIM=1536

# Misc
LOG_LEVEL=INFO
ENVIRONMENT=local
